# ===========================================
# CONFIGURACIÓN DE ENTORNO PARA CORE FRONTEND
# Guardar este archivo como '.env' en esta misma carpeta (docker/core-frontend/.env)
# ===========================================

# Entorno de Node.js
NODE_ENV=production

# URL de la API del Gateway de Core (El backend expone este puerto para llamadas REST)
# IMPORTANTE: Reemplaza 'localhost' o la IP con la IP pública o el dominio accesible de tu servidor GCP
REACT_APP_API_URL=http://<IP_PUBLICA_DE_TU_SERVIDOR_GCP>:8090
