# =========================================================================
# CONFIGURACIÓN GENERAL PARA CORE BACKEND (COMPARTIDA)
# Guardar este archivo como '.env' en esta misma carpeta (docker/core/.env)
# =========================================================================

# Usuario de Docker Hub para las imágenes (por defecto andrescarrillo2001)
DOCKER_USERNAME=andrescarrillo2001

# Entorno activo de Spring Boot (producción)
SPRING_PROFILES_ACTIVE=prod

# =========================================================================
# CONFIGURACIÓN CORE BACKEND (EXTRACTO DE COMUNES)
# =========================================================================
TZ=America/Guayaquil
SPRING_PROFILES_ACTIVE=docker
JPA_DDL_AUTO=validate
HIBERNATE_DDL_AUTO=validate
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=1
ACTUATOR_ENDPOINTS=health,info
ACTUATOR_EXPOSURE=health,info
ACTUATOR_HEALTH_DETAILS=always
ACTUATOR_HEALTH_SHOW_DETAILS=always
MANAGEMENT_HEALTH_DETAILS=always
OPENAPI_DOCS_PATH=/api-docs
SWAGGER_UI_PATH=/swagger-ui.html
HIBERNATE_FORMAT_SQL=false

# Bases de datos comunes y Credenciales por defecto (si no están definidas en host)
MYSQL_HOST=172.17.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=banquito_secure_pass

# Nombres de bases de datos individuales
IDENTITY_DB_NAME=banquito_identity
CUSTOMER_DB_NAME=banquito_customer
ADMIN_DB_NAME=banquito_admin
ACCOUNTING_DB_NAME=banquito_accounting
ACCOUNT_DB_NAME=banquito_account
NOTIFICATION_DB_NAME=banquito_notification
MONGODB_URI=mongodb://172.17.0.1:27017/banquito_documents?authSource=admin

# Parámetros compartidos del pool de conexiones DB
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000

# Claves de Seguridad & Integración
JWT_ISSUER=banquito-issuer
JWT_SECRET=banquito-secret-key-change-me-in-production-1234567890!
INTERNAL_SERVICE_KEY=banquito-internal-key

NOTIFICATION_DELIVERY_MODE=SMTP
NOTIFICATION_PROVIDER=SMTP
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false
SMTP_FROM=no-reply@banquito.com
SMTP_REPLY_TO=
MAILPIT_MAX_MESSAGES=5000