# ==========================================
# CONFIGURACIÓN DE ENTORNO PARA CORE BACKEND
# Guardar este archivo como '.env' en esta misma carpeta (docker/core/.env)
# ==========================================

# Usuario de Docker Hub para las imágenes (por defecto andrescarrillo2001)
DOCKER_USERNAME=andrescarrillo2001

# Entorno activo de Spring Boot (producción)
SPRING_PROFILES_ACTIVE=prod

# Configuración de la base de datos Postgres/MySQL/MongoDB para los microservicios de Core
DB_HOST=172.17.0.1
DB_PORT=5432
DB_USER=banquito_core_user
DB_PASSWORD=banquito_core_secure_password
DB_NAME=banquito_core

# Nota: Si tus microservicios de Spring Boot leen directamente los parámetros
# de conexión de Spring de variables específicas, descomenta y adapta las siguientes:
# SPRING_DATASOURCE_URL=jdbc:postgresql://172.17.0.1:5432/banquito_core
# SPRING_DATASOURCE_USERNAME=banquito_core_user
# SPRING_DATASOURCE_PASSWORD=banquito_core_secure_password
