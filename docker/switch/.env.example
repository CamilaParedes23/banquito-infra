# Banco BanQuito Switch - Docker Compose production-like cloud deployment example
# Copy this file to .env.cloud.prod and replace placeholders before running docker compose.

# Shared PostgreSQL cloud connection
DB_HOST=34.67.150.235
DB_PORT=5432
DB_USERNAME=switch_app
DB_PASSWORD=Switch_g2
DB_JDBC_OPTIONS=?sslmode=require
SPRING_SQL_INIT_MODE=never
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=3
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1

# Docker log rotation
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# RabbitMQ
RABBITMQ_USERNAME=<rabbitmq-user>
RABBITMQ_PASSWORD=<rabbitmq-password>

# Host exposure for Kong in another VM
SWITCH_BATCH_BIND_IP=10.128.0.9
BATCH_HOST_PORT=8016
SWITCH_REPORTING_BIND_IP=10.128.0.9
REPORTING_HOST_PORT=8019

# Published host ports
SFTP_PORT=2222

# Core REST via Kong/API Manager
CORE_KONG_BASE_URL=http://10.128.0.8:8000
CORE_KONG_CUSTOMERS_BY_IDENTIFICATION_PATH=/api/v1/customers/by-identification/{identification}
CORE_KONG_ACCOUNT_BY_NUMBER_PATH=/api/v1/accounts/{accountNumber}
CORE_KONG_AUTH_TOKEN=
CORE_KONG_CLIENT_TOKEN_ENABLED=true
CORE_KONG_CLIENT_ID=switch-pagos-internos-service
CORE_KONG_CLIENT_SECRET=BanQuitoKong2026!
CORE_KONG_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_CUSTOMER_REQUIRED_SCOPE=customer.read
CORE_KONG_ACCOUNT_REQUIRED_SCOPE=account.read
CORE_KONG_RESERVATION_CREATE_REQUIRED_SCOPE=core.reserve.create
CORE_KONG_RESERVATION_CONSUME_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_SERVICE_FEE_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_CLIENT_TOKEN_PATH=/api/v1/auth/client-token
CORE_KONG_CLIENT_TOKEN_REFRESH_SKEW_SECONDS=60

# Core REST via Kong/API Manager
CORE_KONG_BASE_URL=http://10.128.0.8:8000
CORE_KONG_CUSTOMERS_BY_IDENTIFICATION_PATH=/api/v1/customers/by-identification/{identification}
CORE_KONG_ACCOUNT_BY_NUMBER_PATH=/api/v1/accounts/{accountNumber}
CORE_KONG_AUTH_TOKEN=
CORE_KONG_CLIENT_TOKEN_ENABLED=true
CORE_KONG_CLIENT_ID=switch-pagos-internos-service
CORE_KONG_CLIENT_SECRET=BanQuitoKong2026!
CORE_KONG_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_CUSTOMER_REQUIRED_SCOPE=customer.read
CORE_KONG_ACCOUNT_REQUIRED_SCOPE=account.read
CORE_KONG_RESERVATION_CREATE_REQUIRED_SCOPE=core.reserve.create
CORE_KONG_RESERVATION_CONSUME_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_SERVICE_FEE_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_CLIENT_TOKEN_PATH=/api/v1/auth/client-token
CORE_KONG_CLIENT_TOKEN_REFRESH_SKEW_SECONDS=60
CORE_SWITCH_DEFAULT_ACCOUNTING_DATE=
CORE_KONG_COMPANY_ACCOUNT_VALIDATION_PATH=/api/v1/accounts/company-account-validation
CORE_KONG_COMPANY_ACCOUNT_VALIDATION_REQUIRED_SCOPE=account.read
# Billing
SWITCH_BILLING_FALLBACK_COMPANY_RUC=1790012345001
SWITCH_BILLING_FALLBACK_SOURCE_ACCOUNT_NUMBER=2200012345

# Notification REST via Kong
NOTIFICATION_KONG_BASE_URL=http://10.128.0.8:8000
NOTIFICATION_KONG_AUTH_TOKEN=
NOTIFICATION_KONG_CLIENT_TOKEN_ENABLED=true
NOTIFICATION_KONG_CLIENT_ID=switch-pagos-internos-service
NOTIFICATION_KONG_CLIENT_SECRET=BanQuitoKong2026!
NOTIFICATION_KONG_REQUIRED_SCOPE=notification.send
NOTIFICATION_KONG_CLIENT_TOKEN_PATH=/api/v1/auth/client-token
NOTIFICATION_KONG_CLIENT_TOKEN_REFRESH_SKEW_SECONDS=60

# Embedded SFTP demo service
SFTP_ENABLED=true
SFTP_USER_EMPRESA_SIERRAAZUL_USERNAME=empresa.sierraazul
SFTP_USER_EMPRESA_SIERRAAZUL_PASSWORD=password
SFTP_USER_EMPRESA_SIERRAAZUL_COMPANY_RUC=1792103456001
BATCH_SERVICE_BASE_URL=http://batch-service:8081
BATCH_SERVICE_UPLOAD_PATH=/api/v1/batches/upload
