# ==========================================
# CONFIGURACIÓN DE ENTORNO PARA SWITCH BACKEND
# Guardar este archivo como '.env' en esta misma carpeta (docker/switch/.env)
# ==========================================

# Usuario de Docker Hub para las imágenes (por defecto andrescarrillo2001)
DOCKER_USERNAME=andrescarrillo2001

# Entorno activo de Spring Boot (producción)
SPRING_PROFILES_ACTIVE=prod

# Configuración de la base de datos Postgres/MySQL/MongoDB para los microservicios del Switch
DB_HOST=172.17.0.1
DB_PORT=5432
DB_USER=banquito_switch_user
DB_PASSWORD=banquito_switch_secure_password
DB_NAME=banquito_switch

# URLs de integración si se requiere comunicación entre el Switch y Core Backend
CORE_API_URL=http://172.17.0.1:8090

# Parámetros adicionales de Spring Boot si se configuran directamente por variables
# SPRING_DATASOURCE_URL=jdbc:postgresql://172.17.0.1:5432/banquito_switch
# SPRING_DATASOURCE_USERNAME=banquito_switch_user
# SPRING_DATASOURCE_PASSWORD=banquito_switch_secure_password
