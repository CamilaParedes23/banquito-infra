# =========================================================================
# CONFIGURACIÓN DE ENTORNO PARA SWITCH FRONTEND (VITE)
# Guardar este archivo como '.env' en esta misma carpeta (docker/switch-frontend/.env)
# =========================================================================

# Puerto del contenedor expuesto al host
FRONTEND_SWITCH_PORT=3002

# Node environment
NODE_ENV=production

# Variables de la aplicación frontend (Vite)
# IMPORTANTE: Reemplaza '<IP_PUBLICA_DE_TU_SERVIDOR_GCP>' con la IP o dominio real de tu API Gateway/Kong
VITE_API_BASE_URL=http://<IP_PUBLICA_DE_TU_SERVIDOR_GCP>:8080
VITE_BASE_PATH=/
VITE_ALLOWED_HOSTS=*
VITE_APP_NAME=Banquito Switch
VITE_APP_SUBTITLE=Plataforma Transaccional
VITE_ENVIRONMENT=production
VITE_MOCK_AUTH_ENABLED=false
